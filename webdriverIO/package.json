{
  "name": "playwright-atf-webdriverio",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#components": "./src/components/index.ts",
    "#components/*": "./src/components/*.ts",
    "#elements": "./src/elements/index.ts",
    "#elements/*": "./src/elements/*.ts",
    "#screens": "./src/screens/index.ts",
    "#screens/*": "./src/screens/*.ts",
    "#support/*": "./src/support/*.ts",
    "#config/*": "./configs/*.ts"
  },
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "test:login": "wdio run ./wdio.conf.ts --spec ./tests/login.test.ts",
    "test:manage-ap": "wdio run ./wdio.conf.ts --spec ./tests/manageAP.test.ts",
    "typecheck": "tsc --noEmit",
    "allure:serve": "allure serve reports/allure-results"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@wdio/allure-reporter": "^8.43.0",
    "@wdio/cli": "^8.43.0",
    "@wdio/globals": "^8.43.0",
    "@wdio/local-runner": "^8.43.0",
    "@wdio/mocha-framework": "^8.43.0",
    "@wdio/spec-reporter": "^8.43.0",
    "chromedriver": "^146.0.4",
    "expect-webdriverio": "^4.15.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "wdio-chromedriver-service": "^8.1.1",
    "webdriverio": "^8.43.0"
  }
}
